/* -----------------------------------------------------------------------------
									 DIVISOR DE FRECUECIA
                                Version 3.1
   -----------------------------------------------------------------------------
  Para clk_in: f = 50 MHz (MAX II EPM240T100C5) 
					T = 20 ns
	
  Para DIV: 25,000,000 (Prueba con CPLD)
					T/2 = 500ms (25,000,000 x 20ns)
					T   = 1 s   (2 x 500ms)
					f   = 1 s   (1s/1s)
	
  Para DIV: 10 (Simulación MODELSIM)
					T/2 = 200ns  (10 x 20ns)
					T   = 400ns  (2 x 200ns)
					f   = 2.5MHz (1/400ns)
	
   -----------------------------------------------------------------------------
	-----------------------------------------------------------------------------
*/

module Divisor_de_Frecuencia #(
	 parameter DIV = 25_000_000)(// (50MHz)/(25MHz)
    input wire clk_in,          
    input wire rst,
    output reg clk_out
);
    reg [$clog2(DIV)-1:0] contador = 0;

    always @(posedge clk_in or posedge rst) begin
        if (rst) begin
            contador <= 0;
            clk_out  <= 0;
        end else if (contador == DIV - 1) begin
            contador <= 0;
            clk_out  <= ~clk_out;
        end else begin
            contador <= contador + 1;
        end
    end
endmodule
